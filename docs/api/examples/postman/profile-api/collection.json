{
  "info": {
    "name": "Profile Service API",
    "description": "Collection for interacting with the Profile Service API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Get API Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"client_id\": \"{{client_id}}\",\n    \"client_secret\": \"{{client_secret}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/auth/token",
              "host": ["{{base_url}}"],
              "path": ["v1", "auth", "token"]
            }
          }
        }
      ]
    },
    {
      "name": "Profiles",
      "item": [
        {
          "name": "List Profiles",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/v1/profiles?page={{page}}&limit={{limit}}&sort={{sort}}&order={{order}}",
              "host": ["{{base_url}}"],
              "path": ["v1", "profiles"],
              "query": [
                {
                  "key": "page",
                  "value": "{{page}}"
                },
                {
                  "key": "limit",
                  "value": "{{limit}}"
                },
                {
                  "key": "sort",
                  "value": "{{sort}}"
                },
                {
                  "key": "order",
                  "value": "{{order}}"
                }
              ]
            }
          }
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/v1/profiles/{{profile_id}}",
              "host": ["{{base_url}}"],
              "path": ["v1", "profiles", "{{profile_id}}"]
            }
          }
        },
        {
          "name": "Create Profile",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"John Doe\",\n    \"email\": \"john.doe@example.com\",\n    \"bio\": \"Software Engineer\",\n    \"image_urls\": [\"https://example.com/image1.jpg\"]\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/profiles",
              "host": ["{{base_url}}"],
              "path": ["v1", "profiles"]
            }
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"John Doe Updated\",\n    \"bio\": \"Senior Software Engineer\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/profiles/{{profile_id}}",
              "host": ["{{base_url}}"],
              "path": ["v1", "profiles", "{{profile_id}}"]
            }
          }
        },
        {
          "name": "Delete Profile",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/v1/profiles/{{profile_id}}",
              "host": ["{{base_url}}"],
              "path": ["v1", "profiles", "{{profile_id}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Monitoring",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{api_key}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/v1/health",
              "host": ["{{base_url}}"],
              "path": ["v1", "health"]
            }
          }
        },
        {
          "name": "Get Metrics",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/v1/metrics?start={{start_time}}&end={{end_time}}&metric={{metric_name}}",
              "host": ["{{base_url}}"],
              "path": ["v1", "metrics"],
              "query": [
                {
                  "key": "start",
                  "value": "{{start_time}}"
                },
                {
                  "key": "end",
                  "value": "{{end_time}}"
                },
                {
                  "key": "metric",
                  "value": "{{metric_name}}"
                }
              ]
            }
          }
        }
      ]
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Add request ID to headers",
          "if (!pm.request.headers.has('X-Request-ID')) {",
          "    pm.request.headers.add({",
          "        key: 'X-Request-ID',",
          "        value: pm.variables.replaceIn('{{$guid}}')",
          "    });",
          "}"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Test response status",
          "pm.test('Status code is 200', function () {",
          "    pm.response.to.have.status(200);",
          "});",
          "",
          "// Test response time",
          "pm.test('Response time is less than 200ms', function () {",
          "    pm.expect(pm.response.responseTime).to.be.below(200);",
          "});",
          "",
          "// Test response format",
          "pm.test('Response is JSON', function () {",
          "    pm.response.to.be.json;",
          "});"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "https://api.profileservice.com",
      "type": "string"
    },
    {
      "key": "token",
      "value": "your-token-here",
      "type": "string"
    },
    {
      "key": "api_key",
      "value": "your-api-key-here",
      "type": "string"
    },
    {
      "key": "profile_id",
      "value": "123",
      "type": "string"
    },
    {
      "key": "page",
      "value": "1",
      "type": "string"
    },
    {
      "key": "limit",
      "value": "10",
      "type": "string"
    },
    {
      "key": "sort",
      "value": "name",
      "type": "string"
    },
    {
      "key": "order",
      "value": "asc",
      "type": "string"
    }
  ]
}
