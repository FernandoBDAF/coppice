{
  "info": {
    "name": "Internal API",
    "description": "Collection for internal service-to-service communication",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Service Authentication",
      "item": [
        {
          "name": "Get Service Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"service_id\": \"{{service_id}}\",\n  \"service_secret\": \"{{service_secret}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/auth/token",
              "host": ["{{base_url}}"],
              "path": ["v1", "auth", "token"]
            }
          }
        },
        {
          "name": "Validate Service Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{service_token}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/auth/validate",
              "host": ["{{base_url}}"],
              "path": ["v1", "auth", "validate"]
            }
          }
        }
      ]
    },
    {
      "name": "Service Health",
      "item": [
        {
          "name": "Get Service Health",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Service-Token",
                "value": "{{service_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/v1/health",
              "host": ["{{base_url}}"],
              "path": ["v1", "health"]
            }
          }
        },
        {
          "name": "Get Service Status",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Service-Token",
                "value": "{{service_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/v1/health/status",
              "host": ["{{base_url}}"],
              "path": ["v1", "health", "status"]
            }
          }
        }
      ]
    },
    {
      "name": "Data Operations",
      "item": [
        {
          "name": "Batch Create Profiles",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-Service-Token",
                "value": "{{service_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"profiles\": [\n    {\n      \"user_id\": \"{{user_id_1}}\",\n      \"data\": {\n        \"name\": \"{{name_1}}\",\n        \"email\": \"{{email_1}}\"\n      }\n    },\n    {\n      \"user_id\": \"{{user_id_2}}\",\n      \"data\": {\n        \"name\": \"{{name_2}}\",\n        \"email\": \"{{email_2}}\"\n      }\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/profiles/batch",
              "host": ["{{base_url}}"],
              "path": ["v1", "profiles", "batch"]
            }
          }
        },
        {
          "name": "Bulk Update Profiles",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "X-Service-Token",
                "value": "{{service_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"updates\": [\n    {\n      \"user_id\": \"{{user_id_1}}\",\n      \"data\": {\n        \"name\": \"{{name_1}}\"\n      }\n    },\n    {\n      \"user_id\": \"{{user_id_2}}\",\n      \"data\": {\n        \"email\": \"{{email_2}}\"\n      }\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/profiles/bulk",
              "host": ["{{base_url}}"],
              "path": ["v1", "profiles", "bulk"]
            }
          }
        },
        {
          "name": "Batch Delete Profiles",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "X-Service-Token",
                "value": "{{service_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_ids\": [\"{{user_id_1}}\", \"{{user_id_2}}\"]\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/profiles/batch",
              "host": ["{{base_url}}"],
              "path": ["v1", "profiles", "batch"]
            }
          }
        }
      ]
    },
    {
      "name": "Event Operations",
      "item": [
        {
          "name": "Publish Internal Event",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-Service-Token",
                "value": "{{service_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"event_type\": \"{{event_type}}\",\n  \"data\": {\n    \"key\": \"value\"\n  },\n  \"metadata\": {\n    \"source\": \"{{source}}\",\n    \"version\": \"{{version}}\"\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/events/internal",
              "host": ["{{base_url}}"],
              "path": ["v1", "events", "internal"]
            }
          }
        },
        {
          "name": "Subscribe to Internal Events",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-Service-Token",
                "value": "{{service_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"event_types\": [\"{{event_type_1}}\", \"{{event_type_2}}\"],\n  \"callback_url\": \"{{callback_url}}\",\n  \"filter\": \"{{filter_expression}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/events/internal/subscribe",
              "host": ["{{base_url}}"],
              "path": ["v1", "events", "internal", "subscribe"]
            }
          }
        }
      ]
    },
    {
      "name": "Service Configuration",
      "item": [
        {
          "name": "Get Service Config",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Service-Token",
                "value": "{{service_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/v1/config",
              "host": ["{{base_url}}"],
              "path": ["v1", "config"]
            }
          }
        },
        {
          "name": "Update Service Config",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "X-Service-Token",
                "value": "{{service_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"settings\": {\n    \"cache_ttl\": {{cache_ttl}},\n    \"rate_limit\": {{rate_limit}},\n    \"timeout\": {{timeout}}\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/config",
              "host": ["{{base_url}}"],
              "path": ["v1", "config"]
            }
          }
        }
      ]
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.request.headers.has('X-Request-ID')) {",
          "    pm.request.headers.add({",
          "        key: 'X-Request-ID',",
          "        value: pm.variables.replaceIn('{{$guid}}')",
          "    });",
          "}"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.test('Status code is 200', function () {",
          "    pm.response.to.have.status(200);",
          "});",
          "",
          "pm.test('Response time is less than 200ms', function () {",
          "    pm.expect(pm.response.responseTime).to.be.below(200);",
          "});",
          "",
          "pm.test('Response is JSON', function () {",
          "    pm.response.to.be.json;",
          "});"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "https://internal.profileservice.com",
      "type": "string"
    },
    {
      "key": "service_id",
      "value": "your-service-id",
      "type": "string"
    },
    {
      "key": "service_secret",
      "value": "your-service-secret",
      "type": "string"
    },
    {
      "key": "service_token",
      "value": "your-service-token",
      "type": "string"
    },
    {
      "key": "user_id_1",
      "value": "user-123",
      "type": "string"
    },
    {
      "key": "user_id_2",
      "value": "user-456",
      "type": "string"
    },
    {
      "key": "name_1",
      "value": "John Doe",
      "type": "string"
    },
    {
      "key": "name_2",
      "value": "Jane Smith",
      "type": "string"
    },
    {
      "key": "email_1",
      "value": "john@example.com",
      "type": "string"
    },
    {
      "key": "email_2",
      "value": "jane@example.com",
      "type": "string"
    },
    {
      "key": "event_type",
      "value": "profile.updated",
      "type": "string"
    },
    {
      "key": "event_type_1",
      "value": "profile.created",
      "type": "string"
    },
    {
      "key": "event_type_2",
      "value": "profile.updated",
      "type": "string"
    },
    {
      "key": "source",
      "value": "profile-service",
      "type": "string"
    },
    {
      "key": "version",
      "value": "1.0",
      "type": "string"
    },
    {
      "key": "callback_url",
      "value": "https://your-service.com/webhook",
      "type": "string"
    },
    {
      "key": "filter_expression",
      "value": "data.user_id = '123'",
      "type": "string"
    },
    {
      "key": "cache_ttl",
      "value": "3600",
      "type": "string"
    },
    {
      "key": "rate_limit",
      "value": "1000",
      "type": "string"
    },
    {
      "key": "timeout",
      "value": "5000",
      "type": "string"
    }
  ]
}
