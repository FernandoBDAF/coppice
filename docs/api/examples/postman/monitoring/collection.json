{
  "info": {
    "name": "Monitoring API",
    "description": "Collection for interacting with the Monitoring API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health Checks",
      "item": [
        {
          "name": "Get Service Health",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{api_key}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/v1/health",
              "host": ["{{base_url}}"],
              "path": ["v1", "health"]
            }
          }
        },
        {
          "name": "Get Detailed Health",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{api_key}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/v1/health/detailed",
              "host": ["{{base_url}}"],
              "path": ["v1", "health", "detailed"]
            }
          }
        },
        {
          "name": "Get Health History",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{api_key}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/v1/health/history?start={{start_time}}&end={{end_time}}",
              "host": ["{{base_url}}"],
              "path": ["v1", "health", "history"],
              "query": [
                {
                  "key": "start",
                  "value": "{{start_time}}"
                },
                {
                  "key": "end",
                  "value": "{{end_time}}"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Metrics",
      "item": [
        {
          "name": "Get Service Metrics",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{api_key}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/v1/metrics?service={{service}}&metric={{metric}}&interval={{interval}}",
              "host": ["{{base_url}}"],
              "path": ["v1", "metrics"],
              "query": [
                {
                  "key": "service",
                  "value": "{{service}}"
                },
                {
                  "key": "metric",
                  "value": "{{metric}}"
                },
                {
                  "key": "interval",
                  "value": "{{interval}}"
                }
              ]
            }
          }
        },
        {
          "name": "Get Custom Metrics",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{api_key}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/v1/metrics/custom?name={{metric_name}}&start={{start_time}}&end={{end_time}}",
              "host": ["{{base_url}}"],
              "path": ["v1", "metrics", "custom"],
              "query": [
                {
                  "key": "name",
                  "value": "{{metric_name}}"
                },
                {
                  "key": "start",
                  "value": "{{start_time}}"
                },
                {
                  "key": "end",
                  "value": "{{end_time}}"
                }
              ]
            }
          }
        },
        {
          "name": "Submit Custom Metric",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{api_key}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{metric_name}}\",\n  \"value\": {{metric_value}},\n  \"labels\": {\n    \"service\": \"{{service}}\",\n    \"environment\": \"{{environment}}\"\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/metrics/custom",
              "host": ["{{base_url}}"],
              "path": ["v1", "metrics", "custom"]
            }
          }
        }
      ]
    },
    {
      "name": "Logs",
      "item": [
        {
          "name": "Query Logs",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{api_key}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/v1/logs?service={{service}}&level={{level}}&start={{start_time}}&end={{end_time}}",
              "host": ["{{base_url}}"],
              "path": ["v1", "logs"],
              "query": [
                {
                  "key": "service",
                  "value": "{{service}}"
                },
                {
                  "key": "level",
                  "value": "{{level}}"
                },
                {
                  "key": "start",
                  "value": "{{start_time}}"
                },
                {
                  "key": "end",
                  "value": "{{end_time}}"
                }
              ]
            }
          }
        },
        {
          "name": "Search Logs",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{api_key}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"{{search_query}}\",\n  \"start_time\": \"{{start_time}}\",\n  \"end_time\": \"{{end_time}}\",\n  \"limit\": {{limit}}\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/logs/search",
              "host": ["{{base_url}}"],
              "path": ["v1", "logs", "search"]
            }
          }
        },
        {
          "name": "Get Log Patterns",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{api_key}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/v1/logs/patterns?service={{service}}&start={{start_time}}&end={{end_time}}",
              "host": ["{{base_url}}"],
              "path": ["v1", "logs", "patterns"],
              "query": [
                {
                  "key": "service",
                  "value": "{{service}}"
                },
                {
                  "key": "start",
                  "value": "{{start_time}}"
                },
                {
                  "key": "end",
                  "value": "{{end_time}}"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Alerts",
      "item": [
        {
          "name": "List Active Alerts",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{api_key}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/v1/alerts",
              "host": ["{{base_url}}"],
              "path": ["v1", "alerts"]
            }
          }
        },
        {
          "name": "Create Alert",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{api_key}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{alert_name}}\",\n  \"condition\": \"{{alert_condition}}\",\n  \"duration\": \"{{alert_duration}}\",\n  \"severity\": \"{{alert_severity}}\",\n  \"notifications\": {\n    \"email\": [\"{{email}}\"],\n    \"slack\": [\"{{slack_channel}}\"]\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/alerts",
              "host": ["{{base_url}}"],
              "path": ["v1", "alerts"]
            }
          }
        },
        {
          "name": "Update Alert",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{api_key}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"condition\": \"{{alert_condition}}\",\n  \"severity\": \"{{alert_severity}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/alerts/{{alert_id}}",
              "host": ["{{base_url}}"],
              "path": ["v1", "alerts", "{{alert_id}}"]
            }
          }
        },
        {
          "name": "Delete Alert",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{api_key}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/v1/alerts/{{alert_id}}",
              "host": ["{{base_url}}"],
              "path": ["v1", "alerts", "{{alert_id}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Traces",
      "item": [
        {
          "name": "Get Trace",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{api_key}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/v1/traces/{{trace_id}}",
              "host": ["{{base_url}}"],
              "path": ["v1", "traces", "{{trace_id}}"]
            }
          }
        },
        {
          "name": "Search Traces",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{api_key}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"service\": \"{{service}}\",\n  \"operation\": \"{{operation}}\",\n  \"start_time\": \"{{start_time}}\",\n  \"end_time\": \"{{end_time}}\",\n  \"min_duration\": \"{{min_duration}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/v1/traces/search",
              "host": ["{{base_url}}"],
              "path": ["v1", "traces", "search"]
            }
          }
        },
        {
          "name": "Get Trace Statistics",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{api_key}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/v1/traces/stats?service={{service}}&start={{start_time}}&end={{end_time}}",
              "host": ["{{base_url}}"],
              "path": ["v1", "traces", "stats"],
              "query": [
                {
                  "key": "service",
                  "value": "{{service}}"
                },
                {
                  "key": "start",
                  "value": "{{start_time}}"
                },
                {
                  "key": "end",
                  "value": "{{end_time}}"
                }
              ]
            }
          }
        }
      ]
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.request.headers.has('X-Request-ID')) {",
          "    pm.request.headers.add({",
          "        key: 'X-Request-ID',",
          "        value: pm.variables.replaceIn('{{$guid}}')",
          "    });",
          "}"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.test('Status code is 200', function () {",
          "    pm.response.to.have.status(200);",
          "});",
          "",
          "pm.test('Response time is less than 200ms', function () {",
          "    pm.expect(pm.response.responseTime).to.be.below(200);",
          "});",
          "",
          "pm.test('Response is JSON', function () {",
          "    pm.response.to.be.json;",
          "});"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "https://monitoring.profileservice.com",
      "type": "string"
    },
    {
      "key": "api_key",
      "value": "your-api-key",
      "type": "string"
    },
    {
      "key": "service",
      "value": "profile-service",
      "type": "string"
    },
    {
      "key": "metric",
      "value": "request_count",
      "type": "string"
    },
    {
      "key": "interval",
      "value": "1h",
      "type": "string"
    },
    {
      "key": "metric_name",
      "value": "custom_metric",
      "type": "string"
    },
    {
      "key": "metric_value",
      "value": "42",
      "type": "string"
    },
    {
      "key": "environment",
      "value": "production",
      "type": "string"
    },
    {
      "key": "level",
      "value": "error",
      "type": "string"
    },
    {
      "key": "start_time",
      "value": "2024-03-19T00:00:00Z",
      "type": "string"
    },
    {
      "key": "end_time",
      "value": "2024-03-20T00:00:00Z",
      "type": "string"
    },
    {
      "key": "search_query",
      "value": "error AND service:profile-service",
      "type": "string"
    },
    {
      "key": "limit",
      "value": "100",
      "type": "string"
    },
    {
      "key": "alert_name",
      "value": "high_error_rate",
      "type": "string"
    },
    {
      "key": "alert_condition",
      "value": "error_rate > 0.1",
      "type": "string"
    },
    {
      "key": "alert_duration",
      "value": "5m",
      "type": "string"
    },
    {
      "key": "alert_severity",
      "value": "critical",
      "type": "string"
    },
    {
      "key": "email",
      "value": "team@example.com",
      "type": "string"
    },
    {
      "key": "slack_channel",
      "value": "#alerts",
      "type": "string"
    },
    {
      "key": "alert_id",
      "value": "alert-123",
      "type": "string"
    },
    {
      "key": "trace_id",
      "value": "trace-123",
      "type": "string"
    },
    {
      "key": "operation",
      "value": "create_profile",
      "type": "string"
    },
    {
      "key": "min_duration",
      "value": "100ms",
      "type": "string"
    }
  ]
}
