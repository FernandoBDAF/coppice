# Microservices Ecosystem Environment Configuration
# =================================================
# This file provides a comprehensive reference for all environment variables
# used across the six microservices in our production-ready distributed system.
# Copy this file to .env and modify values as needed for your environment.

# =============================================================================
# GLOBAL CONFIGURATION
# =============================================================================

# Environment Settings
ENVIRONMENT=development                    # development|staging|production
LOG_LEVEL=info                            # debug|info|warn|error
METRICS_ENABLED=true                      # Enable Prometheus metrics collection
HEALTH_CHECK_ENABLED=true                 # Enable health check endpoints
GRACEFUL_SHUTDOWN_TIMEOUT=30s             # Graceful shutdown timeout

# Kubernetes Namespace
NAMESPACE=microservices                   # Kubernetes namespace for all services

# =============================================================================
# SERVICE DISCOVERY AND NETWORKING
# =============================================================================

# Service URLs (HTTP-based integration)
AUTH_SERVICE_URL=http://auth-service:8080
PROFILE_SERVICE_URL=http://profile-service:8080
CACHE_SERVICE_URL=http://cache-service:8080
STORAGE_SERVICE_URL=http://storage-service:8080
QUEUE_SERVICE_URL=http://queue-service:8080
WORKER_SERVICE_URL=http://worker-service:8080

# Service Ports
AUTH_SERVICE_PORT=8080
PROFILE_SERVICE_PORT=8080
CACHE_SERVICE_PORT=8080
STORAGE_SERVICE_PORT=8080
QUEUE_SERVICE_PORT=8080
WORKER_SERVICE_PORT=8080

# =============================================================================
# AUTHENTICATION AND SECURITY
# =============================================================================

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY=3600                          # JWT token expiry in seconds (1 hour)
JWT_REFRESH_EXPIRY=86400                 # Refresh token expiry in seconds (24 hours)
JWT_ISSUER=microservices-auth            # JWT issuer identifier
JWT_AUDIENCE=microservices-api           # JWT audience identifier

# Password Security
PASSWORD_MIN_LENGTH=8                    # Minimum password length
PASSWORD_HASH_COST=12                    # Argon2 hash cost (production: 12-15)
PASSWORD_SALT_LENGTH=32                  # Salt length for password hashing

# Account Security
MAX_LOGIN_ATTEMPTS=5                     # Maximum failed login attempts
ACCOUNT_LOCKOUT_DURATION=1800           # Account lockout duration in seconds (30 min)
RATE_LIMIT_REQUESTS=100                 # Rate limit requests per window
RATE_LIMIT_WINDOW=60                    # Rate limit window in seconds

# Session Management
SESSION_TIMEOUT=3600                     # Session timeout in seconds (1 hour)
SESSION_CLEANUP_INTERVAL=300            # Session cleanup interval in seconds (5 min)

# =============================================================================
# DATABASE CONFIGURATION (PostgreSQL)
# =============================================================================

# PostgreSQL Connection (Storage Service)
POSTGRES_HOST=postgresql                 # PostgreSQL host
POSTGRES_PORT=5432                      # PostgreSQL port
POSTGRES_DB=microservices               # Database name
POSTGRES_USER=postgres                  # Database user
POSTGRES_PASSWORD=your-postgres-password # Database password (change in production)
POSTGRES_SSLMODE=disable                # SSL mode: disable|require|verify-ca|verify-full

# Connection Pool Settings
POSTGRES_MAX_OPEN_CONNS=25              # Maximum open connections
POSTGRES_MAX_IDLE_CONNS=5               # Maximum idle connections
POSTGRES_CONN_MAX_LIFETIME=300          # Connection max lifetime in seconds

# Migration Settings
POSTGRES_MIGRATE_ON_START=true          # Run migrations on service start
POSTGRES_MIGRATION_PATH=./migrations    # Path to migration files

# =============================================================================
# CACHE CONFIGURATION (Redis)
# =============================================================================

# Redis Connection (Cache Service Backend)
REDIS_HOST=redis                        # Redis host
REDIS_PORT=6379                         # Redis port
REDIS_PASSWORD=                         # Redis password (empty for no auth)
REDIS_DB=0                              # Redis database number
REDIS_TIMEOUT=5s                        # Redis operation timeout

# Redis Pool Settings
REDIS_POOL_SIZE=10                      # Connection pool size
REDIS_MIN_IDLE_CONNS=5                  # Minimum idle connections
REDIS_POOL_TIMEOUT=4s                   # Pool timeout

# Cache Service HTTP Configuration
CACHE_HOST=cache-service                # Cache service host (HTTP API)
CACHE_PORT=8080                         # Cache service port (HTTP API)
CACHE_TIMEOUT=5s                        # HTTP cache client timeout
CACHE_RETRIES=3                         # HTTP cache client retries
CACHE_ENABLED=true                      # Enable caching

# TTL Configuration
CACHE_PROFILE_TTL=3600                  # Profile cache TTL in seconds (1 hour)
CACHE_SESSION_TTL=86400                 # Session cache TTL in seconds (24 hours)
CACHE_TASK_TTL=1800                     # Task cache TTL in seconds (30 minutes)
CACHE_DEFAULT_TTL=300                   # Default cache TTL in seconds (5 minutes)

# =============================================================================
# MESSAGE QUEUE CONFIGURATION (RabbitMQ)
# =============================================================================

# RabbitMQ Connection
RABBITMQ_HOST=rabbitmq                  # RabbitMQ host
RABBITMQ_PORT=5672                      # RabbitMQ AMQP port
RABBITMQ_USER=admin                     # RabbitMQ user
RABBITMQ_PASSWORD=your-rabbitmq-password # RabbitMQ password (change in production)
RABBITMQ_VHOST=/                        # RabbitMQ virtual host
RABBITMQ_MANAGEMENT_PORT=15672          # RabbitMQ management UI port

# Queue Configuration
QUEUE_ENABLED=true                      # Enable queue processing
QUEUE_PREFETCH_COUNT=1                  # Message prefetch count
QUEUE_AUTO_ACK=false                    # Auto-acknowledge messages
QUEUE_DURABLE=true                      # Durable queues
QUEUE_EXCLUSIVE=false                   # Exclusive queues
QUEUE_AUTO_DELETE=false                 # Auto-delete queues

# Publisher Settings
PUBLISHER_CONFIRMS=true                 # Enable publisher confirms
PUBLISHER_CONFIRM_TIMEOUT=10s           # Publisher confirm timeout
PUBLISHER_RETRY_ATTEMPTS=3              # Retry attempts for failed publishes
PUBLISHER_RETRY_DELAY=1s                # Delay between retry attempts

# Consumer Settings
CONSUMER_AUTO_RECONNECT=true            # Auto-reconnect on connection loss
CONSUMER_RECONNECT_DELAY=5s             # Delay before reconnection attempt
CONSUMER_MAX_RECONNECT_ATTEMPTS=10      # Maximum reconnection attempts

# Exchange and Queue Names
TASKS_EXCHANGE=tasks-exchange           # Main tasks exchange
EMAIL_EXCHANGE=email-tasks              # Email tasks exchange
IMAGE_EXCHANGE=image-tasks              # Image tasks exchange

PROFILE_QUEUE=profile-processing        # Profile processing queue
EMAIL_QUEUE=email-processing            # Email processing queue
IMAGE_QUEUE=image-processing            # Image processing queue

# Routing Keys
PROFILE_ROUTING_KEY=profile.task        # Profile task routing key
EMAIL_ROUTING_KEY=email.send            # Email task routing key
IMAGE_ROUTING_KEY=image.process         # Image task routing key

# =============================================================================
# WORKER SERVICE CONFIGURATION
# =============================================================================

# Worker Types
WORKER_TYPE=multi                       # Worker type: multi|email|image|profile
WORKER_CONCURRENCY=1                    # Number of concurrent workers

# Email Worker Configuration
EMAIL_WORKER_ENABLED=true               # Enable email worker
EMAIL_WORKER_REPLICAS=2                 # Default replicas
EMAIL_WORKER_MAX_REPLICAS=15            # Maximum replicas for scaling
EMAIL_WORKER_PREFETCH=5                 # Prefetch count for email worker
EMAIL_WORKER_TIMEOUT=30s                # Email processing timeout

# Image Worker Configuration
IMAGE_WORKER_ENABLED=true               # Enable image worker
IMAGE_WORKER_REPLICAS=1                 # Default replicas
IMAGE_WORKER_MAX_REPLICAS=8             # Maximum replicas for scaling
IMAGE_WORKER_PREFETCH=1                 # Prefetch count for image worker
IMAGE_WORKER_TIMEOUT=300s               # Image processing timeout (5 minutes)

# Profile Worker Configuration
PROFILE_WORKER_ENABLED=true             # Enable profile worker
PROFILE_WORKER_REPLICAS=1               # Default replicas
PROFILE_WORKER_MAX_REPLICAS=5           # Maximum replicas for scaling
PROFILE_WORKER_PREFETCH=1               # Prefetch count for profile worker
PROFILE_WORKER_TIMEOUT=60s              # Profile processing timeout

# =============================================================================
# CIRCUIT BREAKER CONFIGURATION
# =============================================================================

# Circuit Breaker Settings (Applied to all service integrations)
CIRCUIT_BREAKER_ENABLED=true            # Enable circuit breaker protection
CIRCUIT_BREAKER_TIMEOUT=10s             # Request timeout
CIRCUIT_BREAKER_MAX_REQUESTS=100        # Maximum concurrent requests
CIRCUIT_BREAKER_ERROR_THRESHOLD=50      # Error percentage threshold
CIRCUIT_BREAKER_REQUEST_THRESHOLD=20    # Minimum requests before evaluation
CIRCUIT_BREAKER_SLEEP_WINDOW=30s        # Sleep window when circuit is open

# Service-Specific Circuit Breaker Overrides
AUTH_CIRCUIT_BREAKER_TIMEOUT=5s         # Auth service timeout
CACHE_CIRCUIT_BREAKER_TIMEOUT=2s        # Cache service timeout
STORAGE_CIRCUIT_BREAKER_TIMEOUT=15s     # Storage service timeout
QUEUE_CIRCUIT_BREAKER_TIMEOUT=10s       # Queue service timeout

# =============================================================================
# MONITORING AND OBSERVABILITY
# =============================================================================

# Prometheus Metrics
PROMETHEUS_ENABLED=true                 # Enable Prometheus metrics
PROMETHEUS_PORT=8080                    # Metrics endpoint port
PROMETHEUS_PATH=/metrics                # Metrics endpoint path
PROMETHEUS_NAMESPACE=microservices      # Metrics namespace
PROMETHEUS_SCRAPE_INTERVAL=30s          # Scrape interval

# Health Check Configuration
HEALTH_CHECK_PORT=8080                  # Health check port
HEALTH_CHECK_PATH=/health               # Health check path
READINESS_CHECK_PATH=/ready             # Readiness check path
LIVENESS_CHECK_PATH=/live               # Liveness check path

# Logging Configuration
LOG_FORMAT=json                         # Log format: json|text
LOG_OUTPUT=stdout                       # Log output: stdout|file
LOG_FILE_PATH=/var/log/service.log      # Log file path (if file output)
LOG_MAX_SIZE=100                        # Max log file size in MB
LOG_MAX_BACKUPS=3                       # Number of log file backups
LOG_MAX_AGE=7                           # Max age of log files in days

# Tracing Configuration
TRACING_ENABLED=false                   # Enable distributed tracing
TRACING_ENDPOINT=http://jaeger:14268/api/traces # Tracing endpoint
TRACING_SERVICE_NAME=microservice       # Service name for tracing
TRACING_SAMPLE_RATE=0.1                 # Sampling rate (0.0-1.0)

# =============================================================================
# KUBERNETES AND DEPLOYMENT CONFIGURATION
# =============================================================================

# Resource Limits
CPU_REQUEST=100m                        # CPU request
CPU_LIMIT=500m                          # CPU limit
MEMORY_REQUEST=128Mi                    # Memory request
MEMORY_LIMIT=512Mi                      # Memory limit

# Auto-scaling Configuration
HPA_ENABLED=true                        # Enable Horizontal Pod Autoscaler
HPA_MIN_REPLICAS=2                      # Minimum replicas
HPA_MAX_REPLICAS=10                     # Maximum replicas
HPA_CPU_TARGET=70                       # Target CPU utilization percentage
HPA_MEMORY_TARGET=80                    # Target memory utilization percentage

# Deployment Strategy
DEPLOYMENT_STRATEGY=RollingUpdate       # Deployment strategy
MAX_UNAVAILABLE=1                       # Max unavailable pods during update
MAX_SURGE=1                             # Max surge pods during update

# Service Configuration
SERVICE_TYPE=ClusterIP                  # Service type: ClusterIP|NodePort|LoadBalancer
SERVICE_PORT=8080                       # Service port
TARGET_PORT=8080                        # Target port

# =============================================================================
# SECURITY AND RBAC CONFIGURATION
# =============================================================================

# RBAC Settings
RBAC_ENABLED=true                       # Enable RBAC
SERVICE_ACCOUNT_NAME=default            # Service account name
RBAC_CREATE=true                        # Create RBAC resources

# Security Context
RUN_AS_NON_ROOT=true                    # Run as non-root user
RUN_AS_USER=1000                        # User ID to run as
RUN_AS_GROUP=1000                       # Group ID to run as
FS_GROUP=1000                           # File system group ID
READ_ONLY_ROOT_FILESYSTEM=true          # Read-only root filesystem

# Network Policies
NETWORK_POLICY_ENABLED=true             # Enable network policies
INGRESS_ENABLED=true                    # Allow ingress traffic
EGRESS_ENABLED=true                     # Allow egress traffic

# =============================================================================
# DEVELOPMENT AND TESTING CONFIGURATION
# =============================================================================

# Development Settings
DEV_MODE=false                          # Enable development mode
DEV_AUTO_RELOAD=false                   # Auto-reload on code changes
DEV_MOCK_EXTERNAL_SERVICES=false       # Mock external service calls
DEV_SEED_DATA=false                     # Seed development data

# Testing Configuration
TEST_MODE=false                         # Enable test mode
TEST_DATABASE_URL=postgres://test:test@localhost:5432/test
TEST_REDIS_URL=redis://localhost:6379/1
TEST_RABBITMQ_URL=amqp://test:test@localhost:5672/test

# Performance Testing
LOAD_TEST_ENABLED=false                 # Enable load testing endpoints
LOAD_TEST_MAX_RPS=1000                  # Maximum requests per second
LOAD_TEST_DURATION=60s                  # Load test duration

# =============================================================================
# BACKUP AND DISASTER RECOVERY
# =============================================================================

# Backup Configuration
BACKUP_ENABLED=false                    # Enable automated backups
BACKUP_SCHEDULE=0 2 * * *               # Backup schedule (cron format)
BACKUP_RETENTION_DAYS=30                # Backup retention period
BACKUP_STORAGE_PATH=/backups            # Backup storage path

# =============================================================================
# EXTERNAL INTEGRATIONS (Optional)
# =============================================================================

# Email Service (for email worker)
SMTP_HOST=smtp.example.com              # SMTP server host
SMTP_PORT=587                           # SMTP server port
SMTP_USER=noreply@example.com           # SMTP username
SMTP_PASSWORD=your-smtp-password        # SMTP password
SMTP_TLS=true                           # Enable TLS
SMTP_FROM=noreply@example.com           # Default from address

# Image Processing Service (for image worker)
IMAGE_STORAGE_PATH=/tmp/images          # Temporary image storage path
IMAGE_MAX_SIZE=10485760                 # Maximum image size in bytes (10MB)
IMAGE_ALLOWED_FORMATS=jpg,jpeg,png,gif  # Allowed image formats
IMAGE_QUALITY=85                        # Image compression quality (1-100)

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Service Features
FEATURE_AUTH_ENABLED=true               # Enable authentication features
FEATURE_CACHE_ENABLED=true              # Enable caching features
FEATURE_QUEUE_ENABLED=true              # Enable queue processing
FEATURE_METRICS_ENABLED=true            # Enable metrics collection
FEATURE_HEALTH_CHECKS_ENABLED=true     # Enable health checks

# Worker Features
FEATURE_EMAIL_WORKER_ENABLED=true       # Enable email worker
FEATURE_IMAGE_WORKER_ENABLED=true       # Enable image worker
FEATURE_PROFILE_WORKER_ENABLED=true     # Enable profile worker

# Advanced Features
FEATURE_CIRCUIT_BREAKER_ENABLED=true    # Enable circuit breakers
FEATURE_RATE_LIMITING_ENABLED=true      # Enable rate limiting
FEATURE_AUDIT_LOGGING_ENABLED=true      # Enable audit logging
FEATURE_DISTRIBUTED_TRACING_ENABLED=false # Enable distributed tracing

# =============================================================================
# NOTES AND DOCUMENTATION
# =============================================================================

# Configuration Notes:
# 1. Change all passwords and secrets in production environments
# 2. Adjust resource limits based on your cluster capacity
# 3. Configure monitoring and alerting for production use
# 4. Review security settings and network policies
# 5. Test backup and recovery procedures
# 6. Validate all service integrations in staging environment
# 7. Monitor performance metrics and adjust scaling parameters

# Security Checklist:
# □ Change default passwords and secrets
# □ Enable TLS for all external communications
# □ Configure proper RBAC permissions
# □ Set up network policies for service isolation
# □ Enable audit logging for security events
# □ Configure rate limiting to prevent abuse
# □ Set up monitoring and alerting for security incidents

# Performance Tuning:
# □ Adjust connection pool sizes based on load
# □ Configure appropriate cache TTL values
# □ Set proper circuit breaker thresholds
# □ Optimize worker concurrency and prefetch settings
# □ Monitor and adjust auto-scaling parameters
# □ Review and optimize database queries
# □ Configure appropriate resource limits and requests

# Operational Readiness:
# □ Set up comprehensive monitoring and alerting
# □ Configure log aggregation and analysis
# □ Test backup and recovery procedures
# □ Document incident response procedures
# □ Set up health checks and readiness probes
# □ Configure proper service discovery
# □ Test deployment and rollback procedures
