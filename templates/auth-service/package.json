{
  "name": "auth-service",
  "version": "1.0.0",
  "description": "Copy-ready RS256/JWKS auth service template (sessions, rotation, lockout, roles)",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "rimraf --glob dist *.tsbuildinfo && tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "keys:init": "bash scripts/gen-keys.sh",
    "clean": "rimraf --glob dist coverage *.tsbuildinfo"
  },
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.220.0",
    "@opentelemetry/instrumentation-express": "^0.68.0",
    "@opentelemetry/instrumentation-http": "^0.220.0",
    "@opentelemetry/instrumentation-pg": "^0.72.0",
    "@opentelemetry/sdk-node": "^0.220.0",
    "bcrypt": "^5.1.1",
    "express": "^4.22.2",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.22.0",
    "pino": "^9.14.0",
    "pino-pretty": "^11.3.0",
    "prom-client": "^15.1.3",
    "uuid": "^9.0.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.20.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^9.0.8",
    "@vitest/coverage-v8": "^2.1.9",
    "rimraf": "^5.0.10",
    "supertest": "^7.2.2",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^2.1.9"
  }
}
